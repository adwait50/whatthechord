{
  "name": "whatthechord",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "songs:scrape": "tsx scripts/scraper.ts",
    "chords:sync": "tsx scripts/sync-chord-catalog.ts",
    "chords:sync:dry": "tsx scripts/sync-chord-catalog.ts --dry-run",
    "chords:sync:full": "npm run chords:sync && npm run chords:meta",
    "chords:sync:all": "npm run chords:sync && npm run chords:meta && npm run chords:diagrams",
    "chords:meta": "tsx scripts/sync-chord-metadata.ts",
    "chords:meta:dry": "tsx scripts/sync-chord-metadata.ts --dry-run",
    "chords:diagrams": "tsx scripts/sync-chord-diagrams.ts --exact",
    "chords:diagrams:basic": "tsx scripts/sync-chord-diagrams.ts --exact --basic-major-minor",
    "chords:diagrams:dry": "tsx scripts/sync-chord-diagrams.ts --dry-run",
    "chords:scrape:scales": "tsx scripts/scrape-scales-chords.ts",
    "chords:scrape:scales:basic": "tsx scripts/scrape-scales-chords.ts --basic-major-minor"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.4",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "puppeteer": "^24.37.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
